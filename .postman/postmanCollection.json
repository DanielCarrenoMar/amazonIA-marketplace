            "exec": [
              "const json = pm.response.json();",
              "pm.environment.set('accessToken', json.accessToken);",
              "pm.environment.set('userId', json.user.id);"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\"fullName\":\"Buyer Test\",\"nationalId\":\"BUYER-123\",\"password\":\"Password123!\",\"email\":\"buyer@test.com\"}"
        },
        "url": {
          "raw": "{{backendBaseUrl}}/auth/register",
