# Ingestor Service — Environment Variables
# Copy to .env and fill with real values

# Upstash Kafka REST credentials (from Upstash dashboard)
KAFKA_REST_URL=
KAFKA_REST_TOKEN=

# API key for authenticating IoT devices / simulators
INGESTOR_API_KEY=dev-api-key-change-in-production

# Server port (default: 3002)
PORT=3002
