# Telemetry Worker — Environment Variables
# Copy to .env and fill with real values

# Upstash Redis REST credentials (Streams)
REDIS_URL=
REDIS_TOKEN=
# MongoDB Atlas connection string
# For the ML/analytics read path, append ?readPreference=secondary
MONGODB_URI=

# Polling interval in milliseconds (how often the worker checks Redis Streams for new messages)
POLL_INTERVAL_MS=30000

# Server port (only used for /health endpoint)
PORT=3003
