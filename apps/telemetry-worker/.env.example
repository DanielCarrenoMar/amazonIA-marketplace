# Telemetry Worker — Environment Variables
# Copy to .env and fill with real values

# Upstash Kafka REST credentials
KAFKA_REST_URL=
KAFKA_REST_TOKEN=

# MongoDB Atlas connection string
# For the ML/analytics read path, append ?readPreference=secondary
MONGODB_URI=

# Polling interval in milliseconds (how often the worker checks Kafka for new messages)
POLL_INTERVAL_MS=5000

# Server port (only used for /health endpoint)
PORT=3003
