{
  "name": "iot-simulator",
  "version": "0.0.1",
  "description": "Synthetic IoT data generator with Gaussian noise and network loss simulation",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "simulate:climate": "tsx src/index.ts --mode climate --sensors 3 --interval 2000 --duration 30",
    "simulate:shipment": "tsx src/index.ts --mode shipment --sensors 2 --interval 1000 --duration 30",
    "simulate:mixed": "tsx src/index.ts --mode mixed --sensors 3 --interval 1500 --duration 60",
    "test": "echo \"No tests yet\" && exit 0"
  },
  "dependencies": {
    "event-types": "workspace:*",
    "dotenv": "^17.4.2"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.7.3"
  }
}
