{
  "info": {
    "name": "AmazonIA Marketplace API",
    "description": "Complete CRUD collection for all marketplace resources. Base URL uses {{baseUrl}} variable — set it to http://localhost:3000.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3000" },
    { "key": "userId",    "value": "REPLACE_WITH_CREATED_USER_UUID" },
    { "key": "sellerId",  "value": "REPLACE_WITH_CREATED_SELLER_UUID" },
    { "key": "categoryId","value": "1" },
    { "key": "tribeId",   "value": "1" },
    { "key": "productId", "value": "REPLACE_WITH_CREATED_PRODUCT_UUID" },
    { "key": "orderId",   "value": "REPLACE_WITH_CREATED_ORDER_UUID" }
  ],
  "item": [
    {
      "name": "ProductCategory",
      "item": [
        {
          "name": "Create Category",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/product-category", "host": ["{{baseUrl}}"], "path": ["product-category"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"categoryName\": \"Electronics\",\n  \"subcategoryName\": \"Smartphones\"\n}"
            }
          }
        },
        {
          "name": "Get All Categories",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/product-category", "host": ["{{baseUrl}}"], "path": ["product-category"] }
          }
        },
        {
          "name": "Get Category by ID",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/product-category/{{categoryId}}", "host": ["{{baseUrl}}"], "path": ["product-category", "{{categoryId}}"] }
          }
        },
        {
          "name": "Update Category",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/product-category/{{categoryId}}", "host": ["{{baseUrl}}"], "path": ["product-category", "{{categoryId}}"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"subcategoryName\": \"Android Phones\"\n}"
            }
          }
        },
        {
          "name": "Delete Category",
          "request": {
            "method": "DELETE",
            "url": { "raw": "{{baseUrl}}/product-category/{{categoryId}}", "host": ["{{baseUrl}}"], "path": ["product-category", "{{categoryId}}"] }
          }
        }
      ]
    },
    {
      "name": "UserAccount",
      "item": [
        {
          "name": "Create User",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/user-account", "host": ["{{baseUrl}}"], "path": ["user-account"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fullName\": \"Juan Pérez\",\n  \"nationalId\": \"V-12345678\",\n  \"email\": \"juan@example.com\",\n  \"passwordHash\": \"hashed_password_here\",\n  \"username\": \"juanperez\",\n  \"age\": 28,\n  \"nationality\": \"Venezuelan\",\n  \"phonePrimary\": \"+58 412 1234567\",\n  \"locationCity\": \"Caracas\",\n  \"locationRegion\": \"Distrito Capital\"\n}"
            }
          }
        },
        {
          "name": "Get All Users",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/user-account", "host": ["{{baseUrl}}"], "path": ["user-account"] }
          }
        },
        {
          "name": "Get User by ID",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/user-account/{{userId}}", "host": ["{{baseUrl}}"], "path": ["user-account", "{{userId}}"] }
          }
        },
        {
          "name": "Update User",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/user-account/{{userId}}", "host": ["{{baseUrl}}"], "path": ["user-account", "{{userId}}"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"phonePrimary\": \"+58 414 9999999\",\n  \"locationCity\": \"Valencia\"\n}"
            }
          }
        },
        {
          "name": "Delete User",
          "request": {
            "method": "DELETE",
            "url": { "raw": "{{baseUrl}}/user-account/{{userId}}", "host": ["{{baseUrl}}"], "path": ["user-account", "{{userId}}"] }
          }
        }
      ]
    },
    {
      "name": "Tribe",
      "item": [
        {
          "name": "Create Tribe",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/tribe", "host": ["{{baseUrl}}"], "path": ["tribe"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Tech Sellers Venezuela\",\n  \"description\": \"A tribe for technology sellers in Venezuela\",\n  \"locationMapboxId\": \"place.1234\",\n  \"locationFormattedAddress\": \"Caracas, Venezuela\"\n}"
            }
          }
        },
        {
          "name": "Get All Tribes",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/tribe", "host": ["{{baseUrl}}"], "path": ["tribe"] }
          }
        },
        {
          "name": "Get Tribe by ID",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/tribe/{{tribeId}}", "host": ["{{baseUrl}}"], "path": ["tribe", "{{tribeId}}"] }
          }
        },
        {
          "name": "Update Tribe",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/tribe/{{tribeId}}", "host": ["{{baseUrl}}"], "path": ["tribe", "{{tribeId}}"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"description\": \"Updated tribe description\"\n}"
            }
          }
        },
        {
          "name": "Delete Tribe",
          "request": {
            "method": "DELETE",
            "url": { "raw": "{{baseUrl}}/tribe/{{tribeId}}", "host": ["{{baseUrl}}"], "path": ["tribe", "{{tribeId}}"] }
          }
        }
      ]
    },
    {
      "name": "Seller",
      "description": "A seller must have an existing UserAccount first. Use the UUID returned from 'Create User'.",
      "item": [
        {
          "name": "Create Seller",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/seller", "host": ["{{baseUrl}}"], "path": ["seller"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"id\": \"{{userId}}\",\n  \"tribeId\": 1,\n  \"rating\": 5,\n  \"description\": \"Top-rated electronics seller\"\n}"
            }
          }
        },
        {
          "name": "Get All Sellers",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/seller", "host": ["{{baseUrl}}"], "path": ["seller"] }
          }
        },
        {
          "name": "Get Seller by ID",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/seller/{{sellerId}}", "host": ["{{baseUrl}}"], "path": ["seller", "{{sellerId}}"] }
          }
        },
        {
          "name": "Update Seller",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/seller/{{sellerId}}", "host": ["{{baseUrl}}"], "path": ["seller", "{{sellerId}}"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"rating\": 4,\n  \"description\": \"Great electronics seller, fast shipping\"\n}"
            }
          }
        },
        {
          "name": "Delete Seller",
          "request": {
            "method": "DELETE",
            "url": { "raw": "{{baseUrl}}/seller/{{sellerId}}", "host": ["{{baseUrl}}"], "path": ["seller", "{{sellerId}}"] }
          }
        }
      ]
    },
    {
      "name": "Product",
      "description": "A product requires an existing Seller (sellerId) and ProductCategory (categoryId).",
      "item": [
        {
          "name": "Create Product",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/product", "host": ["{{baseUrl}}"], "path": ["product"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"sellerId\": \"{{sellerId}}\",\n  \"categoryId\": 1,\n  \"name\": \"Samsung Galaxy S24\",\n  \"description\": \"Latest Samsung flagship smartphone\",\n  \"price\": 799.99,\n  \"stockAvailable\": 50,\n  \"locationCity\": \"Caracas\",\n  \"locationRegion\": \"Distrito Capital\"\n}"
            }
          }
        },
        {
          "name": "Get All Products",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/product", "host": ["{{baseUrl}}"], "path": ["product"] }
          }
        },
        {
          "name": "Get Product by ID",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/product/{{productId}}", "host": ["{{baseUrl}}"], "path": ["product", "{{productId}}"] }
          }
        },
        {
          "name": "Update Product",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/product/{{productId}}", "host": ["{{baseUrl}}"], "path": ["product", "{{productId}}"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"price\": 749.99,\n  \"stockAvailable\": 45\n}"
            }
          }
        },
        {
          "name": "Delete Product",
          "request": {
            "method": "DELETE",
            "url": { "raw": "{{baseUrl}}/product/{{productId}}", "host": ["{{baseUrl}}"], "path": ["product", "{{productId}}"] }
          }
        }
      ]
    },
    {
      "name": "ProductOrder",
      "description": "An order requires an existing Product (productId) and a buyer UserAccount (buyerId).",
      "item": [
        {
          "name": "Create Order",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/product-order", "host": ["{{baseUrl}}"], "path": ["product-order"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"productId\": \"{{productId}}\",\n  \"buyerId\": \"{{userId}}\",\n  \"quantity\": 2,\n  \"totalAmount\": 1599.98,\n  \"orderNotes\": \"Please deliver in the morning\",\n  \"currentStatus\": \"PENDING\"\n}"
            }
          }
        },
        {
          "name": "Get All Orders",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/product-order", "host": ["{{baseUrl}}"], "path": ["product-order"] }
          }
        },
        {
          "name": "Get Order by ID",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/product-order/{{orderId}}", "host": ["{{baseUrl}}"], "path": ["product-order", "{{orderId}}"] }
          }
        },
        {
          "name": "Update Order Status (PAID)",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/product-order/{{orderId}}", "host": ["{{baseUrl}}"], "path": ["product-order", "{{orderId}}"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"currentStatus\": \"PAID\",\n  \"transactionHash\": \"0xabc123def456...\"\n}"
            }
          }
        },
        {
          "name": "Cancel Order",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/product-order/{{orderId}}", "host": ["{{baseUrl}}"], "path": ["product-order", "{{orderId}}"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"currentStatus\": \"CANCELED\"\n}"
            }
          }
        },
        {
          "name": "Delete Order",
          "request": {
            "method": "DELETE",
            "url": { "raw": "{{baseUrl}}/product-order/{{orderId}}", "host": ["{{baseUrl}}"], "path": ["product-order", "{{orderId}}"] }
          }
        }
      ]
    },
    {
      "name": "ProductRating",
      "description": "Composite key uses both productId and userAccountId in URLs",
      "item": [
        {
          "name": "Create Rating",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/product-rating", "host": ["{{baseUrl}}"], "path": ["product-rating"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"productId\": \"{{productId}}\",\n  \"userAccountId\": \"{{userId}}\",\n  \"ratingValue\": 5\n}"
            }
          }
        },
        {
          "name": "Get All Ratings",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/product-rating", "host": ["{{baseUrl}}"], "path": ["product-rating"] }
          }
        },
        {
          "name": "Get Rating by Composite ID",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/product-rating/{{productId}}/{{userId}}", "host": ["{{baseUrl}}"], "path": ["product-rating", "{{productId}}", "{{userId}}"] }
          }
        },
        {
          "name": "Update Rating",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/product-rating/{{productId}}/{{userId}}", "host": ["{{baseUrl}}"], "path": ["product-rating", "{{productId}}", "{{userId}}"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"ratingValue\": 4\n}"
            }
          }
        },
        {
          "name": "Delete Rating",
          "request": {
            "method": "DELETE",
            "url": { "raw": "{{baseUrl}}/product-rating/{{productId}}/{{userId}}", "host": ["{{baseUrl}}"], "path": ["product-rating", "{{productId}}", "{{userId}}"] }
          }
        }
      ]
    }
  ]
}
