{
  "info": {
    "_postman_id": "amazonia-marketplace-v4",
    "name": "AmazonIA Marketplace API",
    "description": "Colección completa del backend. Cubre todos los endpoints con guards correctos.\n\n**Usuarios de prueba (Password: Password123!)**\n- 🛒 Comprador: comprador@amazonia.com\n- 🏪 Vendedor 1 (Electrónica): vendedor1@amazonia.com\n- 🏪 Vendedor 2 (Moda): vendedor2@amazonia.com\n\n**Setup rápido:**\n1. Ejecuta 'Login (Comprador) ← EMPIEZA AQUÍ'\n2. El `accessToken` se guarda automáticamente\n3. Todas las rutas 🔒 lo usarán automáticamente",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl",      "value": "http://localhost:3001", "type": "string" },
    { "key": "accessToken",  "value": "",                     "type": "string" },
    { "key": "sellerUserId", "value": "",                     "type": "string" },
    { "key": "buyerUserId",  "value": "",                     "type": "string" },
    { "key": "productId",    "value": "",                     "type": "string" },
    { "key": "orderId",      "value": "",                     "type": "string" },
    { "key": "tribeId",      "value": "",                     "type": "string" },
    { "key": "categoryId",   "value": "",                     "type": "string" }
  ],
  "item": [

    {
      "name": "🔑 Auth",
      "item": [
        {
          "name": "Login (Comprador) ← EMPIEZA AQUÍ",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.accessToken) {",
                  "  pm.collectionVariables.set('accessToken', res.accessToken);",
                  "  console.log('✅ accessToken guardado automáticamente');",
                  "}",
                  "if (res.user && res.user.id) {",
                  "  pm.collectionVariables.set('buyerUserId', res.user.id);",
                  "  console.log('✅ buyerUserId guardado: ' + res.user.id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "login"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"comprador@amazonia.com\",\n  \"password\": \"Password123!\"\n}"
            },
            "description": "Login como comprador. Guarda automáticamente `accessToken` y `buyerUserId`."
          }
        },
        {
          "name": "Login (Vendedor 1 - Electrónica)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.accessToken) {",
                  "  pm.collectionVariables.set('accessToken', res.accessToken);",
                  "  console.log('✅ accessToken guardado automáticamente');",
                  "}",
                  "if (res.user && res.user.id) {",
                  "  pm.collectionVariables.set('sellerUserId', res.user.id);",
                  "  console.log('✅ sellerUserId guardado: ' + res.user.id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "login"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"vendedor1@amazonia.com\",\n  \"password\": \"Password123!\"\n}"
            },
            "description": "Login como Vendedor 1. Guarda automáticamente `accessToken` y `sellerUserId`."
          }
        },
        {
          "name": "Login (Vendedor 2 - Moda)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.accessToken) {",
                  "  pm.collectionVariables.set('accessToken', res.accessToken);",
                  "  console.log('✅ accessToken guardado automáticamente');",
                  "}",
                  "if (res.user && res.user.id) {",
                  "  pm.collectionVariables.set('sellerUserId', res.user.id);",
                  "  console.log('✅ sellerUserId guardado: ' + res.user.id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "login"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"vendedor2@amazonia.com\",\n  \"password\": \"Password123!\"\n}"
            },
            "description": "Login como Vendedor 2 (José Rodríguez)."
          }
        },
        {
          "name": "Register (Nuevo Usuario)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": {
              "raw": "{{baseUrl}}/auth/register",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "register"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fullName\": \"Ana Martínez\",\n  \"nationalId\": \"V-44444444\",\n  \"email\": \"ana@amazonia.com\",\n  \"password\": \"Password123!\",\n  \"username\": \"anamtz\",\n  \"age\": 25,\n  \"nationality\": \"Venezolana\",\n  \"phonePrimary\": \"+58 412 9999999\"\n}"
            },
            "description": "Crea un nuevo usuario y devuelve tokens de inmediato. Ruta pública."
          }
        },
        {
          "name": "Refresh Token",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": {
              "raw": "{{baseUrl}}/auth/refresh",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "refresh"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"<pega_el_refreshToken_aqui>\"\n}"
            },
            "description": "Acepta un refreshToken válido (7d) y devuelve un nuevo par de tokens (rotación)."
          }
        },
        {
          "name": "🔒 Mi Perfil (GET /auth/me)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/auth/me",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "me"]
            },
            "description": "Devuelve el payload del JWT del usuario autenticado."
          }
        }
      ]
    },

