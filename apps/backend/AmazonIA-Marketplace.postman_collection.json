      "name": "🔑 Auth",
      "item": [
        {
          "name": "Login (Comprador) ← EMPIEZA AQUÍ",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.accessToken) {",
                  "  pm.collectionVariables.set('accessToken', res.accessToken);",
                  "  console.log('✅ accessToken guardado automáticamente');",
                  "}",
                  "if (res.user && res.user.id) {",
                  "  pm.collectionVariables.set('buyerUserId', res.user.id);",
                  "  console.log('✅ buyerUserId guardado: ' + res.user.id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"comprador@amazonia.com\",\n  \"password\": \"Password123!\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "login"
              ]
            },
            "description": "Login como comprador. Guarda automáticamente `accessToken` y `buyerUserId`."
          },
