DATABASE_URL="postgresql://user:password@host/dbname"

# Generate JWT SECRET with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="your_jwt_secret_here"
JWT_REFRESH_SECRET="your_jwt_refresh_secret_here"

# Comunicación Interna (API Key compartida con blockchain-notary)
NOTARY_API_KEY="your_notary_api_key_here"

# URL del microservicio notario (blockchain-notary)
NOTARY_SERVICE_URL="http://localhost:3001/api/v1"

# URL base del backend para webhooks (el notario llamará aquí)
WEBHOOK_BASE_URL="http://localhost:3000/api"
