# URL del nodo RPC de la Blockchain (ej. Alchemy, Infura para Arbitrum)
RPC_URL="https://arb-sepolia.g.alchemy.com/v2/your_alchemy_key_here"

# Llave privada de la billetera corporativa que asume los costos de gas
# ¡NUNCA uses una cuenta real en desarrollo!
PRIVATE_KEY="your_wallet_private_key_here"

# Dirección del contrato inteligente NotaryRegistry desplegado
CONTRACT_ADDRESS="0xYourContractAddressHere"

# Clave de API para asegurar el endpoint (compartida con backend)
API_KEY="your_notary_api_key_here"

# Nombre de la red blockchain
NETWORK_NAME="arbitrum-sepolia"

# Máximo de reintentos para transacciones fallidas
MAX_RETRY_ATTEMPTS=3

# Puerto del microservicio
PORT=3001

# URL de la base de datos compartida (misma que el backend)
DATABASE_URL="postgresql://user:password@host/dbname"
