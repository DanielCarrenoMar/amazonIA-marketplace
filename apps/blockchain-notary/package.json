{
  "name": "blockchain-notary",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "build": "prisma generate && nest build",
    "format": "prettier --write \"src/**/*.ts\"",
    "dev": "nest start --watch",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "compile": "hardhat compile",
    "deploy:local": "hardhat run scripts/deploy-governance.ts --network localhost",
    "deploy:sepolia": "hardhat run scripts/deploy-governance.ts --network arbitrumSepolia",
    "node:local": "hardhat node"
  },
  "dependencies": {
    "@nestjs/common": "^10.0.0",
    "@nestjs/config": "^3.2.0",
    "@nestjs/core": "^10.0.0",
    "@nestjs/platform-express": "^10.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "ethers": "^6.13.0",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.8.1",
    "@prisma/client": "^6.0.0",
    "event-types": "workspace:*"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.0.0",
    "@types/express": "^4.17.17",
    "@types/node": "^20.3.1",
    "eslint": "^8.42.0",
    "prisma": "^6.0.0",
    "typescript": "^5.1.3",
    "hardhat": "^2.22.0",
    "@nomicfoundation/hardhat-toolbox": "^5.0.0"
  }
}