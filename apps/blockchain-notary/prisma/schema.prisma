generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model BlockchainRecord {
  id              String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orderId         String           @unique @map("order_id") @db.Uuid
  transactionHash String?          @map("transaction_hash") @db.VarChar(255)
  blockNumber     Int?             @map("block_number")
  networkName     String           @default("arbitrum") @map("network_name") @db.VarChar(50)
  status          BlockchainStatus @default(PENDING)
  retryCount      Int              @default(0) @map("retry_count")
  errorMessage    String?          @map("error_message")
  gasUsed         String?          @map("gas_used") @db.VarChar(50)
  submittedAt     DateTime?        @map("submitted_at") @db.Timestamptz(6)
  confirmedAt     DateTime?        @map("confirmed_at") @db.Timestamptz(6)
  createdAt       DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  nftMintedAt     DateTime?        @map("nft_minted_at") @db.Timestamptz(6)
  nftTokenId      String?          @map("nft_token_id") @db.VarChar(100)
  nftTxHash       String?          @map("nft_tx_hash") @db.VarChar(255)
  webhookUrl      String?          @map("webhook_url") @db.VarChar(512)
  product_order   product_order    @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([transactionHash])
  @@index([nftTokenId])
  @@map("blockchain_record")
}

model GovernanceMember {
  id            String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId        String         @unique @map("user_id")
  walletAddress String         @unique @map("wallet_address") @db.VarChar(42)
  role          GovernanceRole @default(NONE)
  assignedAt    DateTime       @default(now()) @map("assigned_at") @db.Timestamptz(6)
  assignedBy    String?        @map("assigned_by")
  votes         Vote[]

  @@index([role])
  @@map("governance_member")
}

model Proposal {
  id              String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  proposalId      String         @unique @map("proposal_id")
  contentHash     String         @map("content_hash")
  proposerUserId  String         @map("proposer_user_id")
  status          ProposalStatus @default(PENDING)
  votesFor        Int            @default(0) @map("votes_for")
  votesAgainst    Int            @default(0) @map("votes_against")
  vetoReason      String?        @map("veto_reason")
  vetoedBy        String?        @map("vetoed_by")
  transactionHash String?        @map("transaction_hash") @db.VarChar(255)
  blockNumber     Int?           @map("block_number")
  gasUsed         String?        @map("gas_used") @db.VarChar(50)
  deadline        DateTime       @map("deadline") @db.Timestamptz(6)
  createdAt       DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  confirmedAt     DateTime?      @map("confirmed_at") @db.Timestamptz(6)
  type            ProposalType   @default(TRANSACTION_NOTARIZATION)
  votes           Vote[]

  @@index([status])
  @@index([status, createdAt])
  @@index([proposerUserId])
  @@map("proposal")
}

model Vote {
  id         String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  proposalId String           @map("proposal_id") @db.Uuid
  voterId    String           @map("voter_id") @db.Uuid
  inFavor    Boolean          @map("in_favor")
  weight     Int              @default(1)
  txHash     String?          @map("tx_hash") @db.VarChar(255)
  createdAt  DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  proposal   Proposal         @relation(fields: [proposalId], references: [id])
  voter      GovernanceMember @relation(fields: [voterId], references: [id])

  @@unique([proposalId, voterId])
  @@map("vote")
}

model Notificaciones {
  id           Int          @id @default(autoincrement())
  id_user      String       @db.Uuid
  tittle       String       @db.VarChar(255)
  messege      String
  isReaded     Boolean      @default(false)
  timesspams   DateTime     @default(now()) @db.Timestamptz(6)
  user_account user_account @relation(fields: [id_user], references: [id], onDelete: Cascade)

  @@index([id_user, isReaded])
}

model chat {
  id_mensaje    Int           @id @default(autoincrement())
  id_pedido     String        @db.Uuid
  id_remitente  String        @db.Uuid
  mensaje       String
  fh_envio      DateTime      @default(now()) @db.Timestamptz(6)
  product_order product_order @relation(fields: [id_pedido], references: [id], onDelete: Cascade)
  user_account  user_account  @relation(fields: [id_remitente], references: [id], onDelete: Cascade)

  @@index([id_pedido, fh_envio])
}

model comentarios_productos {
  id_comentario               Int                     @id @default(autoincrement())
  id_producto                 String                  @db.Uuid
  id_usuario                  String                  @db.Uuid
  comentario                  String
  id_respuesta                Int?
  fh_publicacion              DateTime                @default(now()) @db.Timestamptz(6)
  product                     product                 @relation(fields: [id_producto], references: [id], onDelete: Cascade)
  comentarios_productos       comentarios_productos?  @relation("comentarios_productosTocomentarios_productos", fields: [id_respuesta], references: [id_comentario])
  other_comentarios_productos comentarios_productos[] @relation("comentarios_productosTocomentarios_productos")
  user_account                user_account            @relation(fields: [id_usuario], references: [id], onDelete: Cascade)
}

model favoritos_usuario {
  id_usuario   String       @db.Uuid
  id_producto  String       @db.Uuid
  fh_creacion  DateTime     @default(now()) @db.Timestamptz(6)
  product      product      @relation(fields: [id_producto], references: [id], onDelete: Cascade)
  user_account user_account @relation(fields: [id_usuario], references: [id], onDelete: Cascade)

  @@id([id_usuario, id_producto])
}

model order_status_history {
  id                 Int                @id @default(autoincrement())
  order_id           String             @db.Uuid
  changed_by_user_id String             @db.Uuid
  previous_status    order_status_enum?
  new_status         order_status_enum
  status_note        String?
  created_at         DateTime           @default(now()) @db.Timestamptz(6)
  user_account       user_account       @relation(fields: [changed_by_user_id], references: [id])
  product_order      product_order      @relation(fields: [order_id], references: [id], onDelete: Cascade)

  @@index([order_id, created_at])
}

model outbox_events {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  aggregate_type String    @db.VarChar(100)
  aggregate_id   String    @db.Uuid
  event_type     String    @db.VarChar(100)
  payload        Json
  created_at     DateTime  @default(now()) @db.Timestamptz(6)
  published_at   DateTime? @db.Timestamptz(6)

  @@index([published_at])
}

model product {
  id                         String                     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  seller_id                  String                     @db.Uuid
  category_id                Int
  name                       String                     @db.VarChar(255)
  description                String?
  price                      Decimal                    @db.Decimal(12, 2)
  stock_available            Int                        @default(0)
  average_rating             Decimal?                   @db.Decimal(3, 2)
  location_coords            Unsupported("geography")?
  location_mapbox_id         String?                    @db.VarChar(100)
  location_formatted_address String?
  location_city              String?                    @db.VarChar(100)
  location_region            String?                    @db.VarChar(100)
  created_at                 DateTime                   @default(now()) @db.Timestamptz(6)
  updated_at                 DateTime                   @db.Timestamptz(6)
  image_url                  String?
  is_active                  Boolean                    @default(true)
  total_reviews              Int                        @default(0)
  elaboration_media_urls     String[]
  elaboration_text           String?
  is_fragile                 Boolean                    @default(false)
  requires_cold_chain        Boolean                    @default(false)
  max_humidity               Decimal?                   @db.Decimal(5, 2)
  max_temperature_celsius    Decimal?                   @db.Decimal(5, 2)
  image_urls                 String[]                   @default([])
  comentarios_productos      comentarios_productos[]
  favoritos_usuario          favoritos_usuario[]
  product_category           product_category           @relation(fields: [category_id], references: [id])
  seller                     seller                     @relation(fields: [seller_id], references: [id], onDelete: Cascade)
  product_elaboration_step   product_elaboration_step[]
  product_order              product_order[]
  product_rating             product_rating[]

  @@index([is_active])
  @@index([location_coords], type: Gist)
  @@index([seller_id])
}

model product_category {
  id               Int       @id @default(autoincrement())
  category_name    String    @db.VarChar(100)
  subcategory_name String?   @db.VarChar(100)
  product          product[]
}

model product_elaboration_step {
  id          Int      @id @default(autoincrement())
  product_id  String   @db.Uuid
  step_number Int
  title       String?  @db.VarChar(255)
  description String
  media_urls  String[]
  created_at  DateTime @default(now()) @db.Timestamptz(6)
  updated_at  DateTime @db.Timestamptz(6)
  product     product  @relation(fields: [product_id], references: [id], onDelete: Cascade)

  @@unique([product_id, step_number])
  @@index([product_id])
}

model product_order {
  id                            String                    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  product_id                    String                    @db.Uuid
  buyer_id                      String                    @db.Uuid
  quantity                      Int
  total_amount                  Decimal                   @db.Decimal(12, 2)
  order_notes                   String?
  seller_rating_value           Int?
  buyer_rating_value            Int?
  transaction_hash              String?                   @db.VarChar(255)
  current_status                order_status_enum         @default(PENDING)
  created_at                    DateTime                  @default(now()) @db.Timestamptz(6)
  updated_at                    DateTime                  @db.Timestamptz(6)
  carrier_id                    Int?
  tracking_number               String?                   @db.VarChar(100)
  sensor_id                     String?                   @db.VarChar(100)
  destination_city              String?                   @db.VarChar(100)
  destination_coords            Unsupported("geography")?
  destination_formatted_address String?
  destination_mapbox_id         String?                   @db.VarChar(100)
  destination_region            String?                   @db.VarChar(100)
  origin_city                   String?                   @db.VarChar(100)
  origin_coords                 Unsupported("geography")?
  origin_formatted_address      String?
  origin_mapbox_id              String?                   @db.VarChar(100)
  origin_region                 String?                   @db.VarChar(100)
  payment_method                String?                   @db.VarChar(50)
  transport_type                transport_type_enum       @default(TERRESTRE)
  blockchain_record             BlockchainRecord?
  chat                          chat[]
  order_status_history          order_status_history[]
  user_account                  user_account              @relation(fields: [buyer_id], references: [id])
  shipping_carrier              shipping_carrier?         @relation(fields: [carrier_id], references: [id])
  product                       product                   @relation(fields: [product_id], references: [id])

  @@index([buyer_id])
  @@index([current_status])
  @@index([sensor_id])
}

model product_rating {
  product_id      String       @db.Uuid
  user_account_id String       @db.Uuid
  rating_value    Int
  created_at      DateTime     @default(now()) @db.Timestamptz(6)
  product         product      @relation(fields: [product_id], references: [id], onDelete: Cascade)
  user_account    user_account @relation(fields: [user_account_id], references: [id], onDelete: Cascade)

  @@id([product_id, user_account_id])
}

model refresh_token {
  id           String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id      String       @db.Uuid
  token_hash   String       @db.VarChar(255)
  expires_at   DateTime     @db.Timestamptz(6)
  revoked_at   DateTime?    @db.Timestamptz(6)
  created_at   DateTime     @default(now()) @db.Timestamptz(6)
  user_account user_account @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([token_hash])
  @@index([user_id])
}

model seller {
  id                                                                       String                     @id @db.Uuid
  tribe_id                                                                 Int?
  rating                                                                   Int?
  description                                                              String?
  avg_product_rating                                                       Float?
  total_reviews                                                            Int                        @default(0)
  product                                                                  product[]
  user_account                                                             user_account               @relation(fields: [id], references: [id], onDelete: Cascade)
  tribe_seller_tribe_idTotribe                                             tribe?                     @relation("seller_tribe_idTotribe", fields: [tribe_id], references: [id])
  tribe_tribe_primary_leader_idToseller                                    tribe?                     @relation("tribe_primary_leader_idToseller")
  tribe_tribe_secondary_leader_idToseller                                  tribe?                     @relation("tribe_secondary_leader_idToseller")
  tribe_membership_request_tribe_membership_request_reviewed_by_idToseller tribe_membership_request[] @relation("tribe_membership_request_reviewed_by_idToseller")
  tribe_membership_request_tribe_membership_request_seller_idToseller      tribe_membership_request[] @relation("tribe_membership_request_seller_idToseller")
}

model shipping_carrier {
  id            Int             @id @default(autoincrement())
  name          String          @unique @db.VarChar(100)
  website       String?         @db.VarChar(255)
  product_order product_order[]
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model spatial_ref_sys {
  srid      Int     @id
  auth_name String? @db.VarChar(256)
  auth_srid Int?
  srtext    String? @db.VarChar(2048)
  proj4text String? @db.VarChar(2048)
}

model tribe {
  id                                       Int                        @id @default(autoincrement())
  name                                     String                     @db.VarChar(255)
  description                              String?
  location_coords                          Unsupported("geography")?
  location_mapbox_id                       String?                    @db.VarChar(100)
  location_formatted_address               String?
  created_at                               DateTime                   @default(now()) @db.Timestamptz(6)
  primary_leader_id                        String?                    @unique @db.Uuid
  requested_by_id                          String?                    @db.Uuid
  review_note                              String?
  reviewed_at                              DateTime?                  @db.Timestamptz(6)
  reviewed_by_id                           String?                    @db.Uuid
  secondary_leader_id                      String?                    @unique @db.Uuid
  status                                   tribe_status_enum          @default(PENDING_APPROVAL)
  seller_seller_tribe_idTotribe            seller[]                   @relation("seller_tribe_idTotribe")
  seller_tribe_primary_leader_idToseller   seller?                    @relation("tribe_primary_leader_idToseller", fields: [primary_leader_id], references: [id])
  seller_tribe_secondary_leader_idToseller seller?                    @relation("tribe_secondary_leader_idToseller", fields: [secondary_leader_id], references: [id])
  tribe_membership_request                 tribe_membership_request[]

  @@index([status])
}

model tribe_membership_request {
  id                                                     Int                            @id @default(autoincrement())
  tribe_id                                               Int
  seller_id                                              String                         @db.Uuid
  status                                                 membership_request_status_enum @default(PENDING)
  message                                                String?
  review_note                                            String?
  reviewed_by_id                                         String?                        @db.Uuid
  reviewed_at                                            DateTime?                      @db.Timestamptz(6)
  created_at                                             DateTime                       @default(now()) @db.Timestamptz(6)
  seller_tribe_membership_request_reviewed_by_idToseller seller?                        @relation("tribe_membership_request_reviewed_by_idToseller", fields: [reviewed_by_id], references: [id])
  seller_tribe_membership_request_seller_idToseller      seller                         @relation("tribe_membership_request_seller_idToseller", fields: [seller_id], references: [id], onDelete: Cascade)
  tribe                                                  tribe                          @relation(fields: [tribe_id], references: [id], onDelete: Cascade)

  @@unique([tribe_id, seller_id])
  @@index([tribe_id, status])
}

model user_account {
  id                         String                    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  username                   String?                   @unique @db.VarChar(50)
  full_name                  String                    @db.VarChar(255)
  national_id                String                    @unique @db.VarChar(50)
  age                        Int?
  nationality                String?                   @db.VarChar(100)
  password_hash              String                    @db.VarChar(255)
  email                      String                    @unique @db.VarChar(255)
  role                       user_role_enum            @default(BUYER)
  phone_primary              String?                   @db.VarChar(50)
  phone_secondary            String?                   @db.VarChar(50)
  wallet_hash                String?                   @db.VarChar(255)
  location_coords            Unsupported("geography")?
  location_mapbox_id         String?                   @db.VarChar(100)
  location_formatted_address String?
  location_city              String?                   @db.VarChar(100)
  location_region            String?                   @db.VarChar(100)
  created_at                 DateTime                  @default(now()) @db.Timestamptz(6)
  avatar_url                 String?                   @db.VarChar(500)
  Notificaciones             Notificaciones[]
  chat                       chat[]
  comentarios_productos      comentarios_productos[]
  favoritos_usuario          favoritos_usuario[]
  order_status_history       order_status_history[]
  product_order              product_order[]
  product_rating             product_rating[]
  refresh_token              refresh_token[]
  seller                     seller?

  @@index([location_coords], type: Gist)
}

enum BlockchainStatus {
  PENDING
  SUBMITTED
  CONFIRMED
  FAILED

  @@map("blockchain_status_enum")
}

enum GovernanceRole {
  NONE
  MEMBER
  ELDER

  @@map("governance_role_enum")
}

enum ProposalStatus {
  PENDING
  APPROVED
  VETOED
  CONFIRMED
  FAILED

  @@map("proposal_status_enum")
}

enum ProposalType {
  TRANSACTION_NOTARIZATION
  TRIBE_ADMISSION
  TRIBE_EXPULSION

  @@map("proposal_type_enum")
}

enum membership_request_status_enum {
  PENDING
  APPROVED
  REJECTED
}

enum order_status_enum {
  PENDING
  PAID
  SHIPPED
  DELIVERED
  CANCELED
  REFUNDED
}

enum transport_type_enum {
  TERRESTRE
  AEREO
  MARITIMO
}

enum tribe_status_enum {
  PENDING_APPROVAL
  ACTIVE
  REJECTED
  SUSPENDED
}

enum user_role_enum {
  BUYER
  SELLER
  ADMIN
}
