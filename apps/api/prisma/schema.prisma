// =============================================================================
// AmazonIA Marketplace — Prisma Schema
// generator : prisma-client (Prisma 7)
// datasource: PostgreSQL + PostGIS
// =============================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  // URL is injected at runtime via prisma.config.ts → process.env.DATABASE_URL
}

// ---------------------------------------------------------------------------
// Enums
enum UserRole {
  BUYER
  SELLER
  ADMIN

  @@map("user_role_enum")
}

// ---------------------------------------------------------------------------

enum OrderStatus {
  PENDING
  PAID
  SHIPPED
  DELIVERED
  CANCELED
  REFUNDED

  @@map("order_status_enum")
}

// ---------------------------------------------------------------------------

enum BlockchainStatus {
  PENDING
  SUBMITTED
  CONFIRMED
  FAILED

  @@map("blockchain_status_enum")
}

// ---------------------------------------------------------------------------

enum TribeStatus {
  PENDING_APPROVAL
  ACTIVE
  REJECTED
  SUSPENDED

  @@map("tribe_status_enum")
}

enum MembershipRequestStatus {
  PENDING
  APPROVED
  REJECTED

  @@map("membership_request_status_enum")
}

// ---------------------------------------------------------------------------
// UserAccount
// ---------------------------------------------------------------------------

model UserAccount {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  username       String?  @unique @db.VarChar(50)
  fullName       String   @map("full_name") @db.VarChar(255)
  nationalId     String   @unique @map("national_id") @db.VarChar(50)
  age            Int?
  nationality    String?  @db.VarChar(100)
  passwordHash   String   @map("password_hash") @db.VarChar(255)
  email          String   @unique @db.VarChar(255)
  role           UserRole @default(BUYER)
  phonePrimary   String?  @map("phone_primary") @db.VarChar(50)
  phoneSecondary String?  @map("phone_secondary") @db.VarChar(50)
  walletHash     String?  @map("wallet_hash") @db.VarChar(255)
  avatarUrl      String?  @map("avatar_url") @db.VarChar(500)

  // Spatial — PostGIS type not natively supported by Prisma
  locationCoords           Unsupported("geography(Point, 4326)")? @map("location_coords")
  locationMapboxId         String?                                @map("location_mapbox_id") @db.VarChar(100)
  locationFormattedAddress String?                                @map("location_formatted_address")
  locationCity             String?                                @map("location_city") @db.VarChar(100)
  locationRegion           String?                                @map("location_region") @db.VarChar(100)

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  // Relations
  seller             Seller?
  productRatings     ProductRating[]
  buyerOrders        ProductOrder[]       @relation("BuyerOrders")
  orderStatusChanges OrderStatusHistory[] @relation("ChangedByUser")
  refreshTokens      RefreshToken[]
  productComments    ProductComment[]
  sentChatMessages   OrderChat[]          @relation("SentChatMessages")

  @@index([locationCoords], type: Gist)
  @@map("user_account")
}

// ---------------------------------------------------------------------------
// Tribe
// ---------------------------------------------------------------------------

model Tribe {
  id          Int         @id @default(autoincrement())
  name        String      @db.VarChar(255)
  description String?
  status      TribeStatus @default(PENDING_APPROVAL)

  // Líderes — FK a Seller
  primaryLeaderId   String? @unique @map("primary_leader_id") @db.Uuid
  secondaryLeaderId String? @unique @map("secondary_leader_id") @db.Uuid

  // Quien solicitó la creación
  requestedById String? @map("requested_by_id") @db.Uuid

  // Admin que aprobó/rechazó
  reviewedById  String?   @map("reviewed_by_id") @db.Uuid
  reviewedAt    DateTime? @map("reviewed_at") @db.Timestamptz
  reviewNote    String?   @map("review_note")

  // Spatial
  locationCoords           Unsupported("geography(Point, 4326)")? @map("location_coords")
  locationMapboxId         String?                                @map("location_mapbox_id") @db.VarChar(100)
  locationFormattedAddress String?                                @map("location_formatted_address")

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  // Relations
  primaryLeader      Seller?                  @relation("TribePrimaryLeader", fields: [primaryLeaderId], references: [id], onDelete: SetNull)
  secondaryLeader    Seller?                  @relation("TribeSecondaryLeader", fields: [secondaryLeaderId], references: [id], onDelete: SetNull)
  sellers            Seller[]                 @relation("TribeMembers")
  membershipRequests TribeMembershipRequest[]

  @@index([status])
  @@map("tribe")
}

// ---------------------------------------------------------------------------
// Seller  (1-to-1 extension of UserAccount)
// ---------------------------------------------------------------------------

model Seller {
  // Shares the same UUID as the parent UserAccount row
  id          String  @id @db.Uuid
  tribeId     Int?    @map("tribe_id")
  rating      Int?
  description String?

  avgProductRating Float? @map("avg_product_rating")
  totalReviews     Int    @default(0) @map("total_reviews")

  // Relations
  user                       UserAccount                @relation(fields: [id], references: [id], onDelete: Cascade)
  tribe                      Tribe?                     @relation("TribeMembers", fields: [tribeId], references: [id], onDelete: SetNull)
  products                   Product[]
  ledTribeAsPrimary          Tribe?                     @relation("TribePrimaryLeader")
  ledTribeAsSecondary        Tribe?                     @relation("TribeSecondaryLeader")
  sentMembershipRequests     TribeMembershipRequest[]   @relation("MembershipRequestedBy")
  reviewedMembershipRequests TribeMembershipRequest[]   @relation("MembershipReviewedBy")

  @@map("seller")
}

// ---------------------------------------------------------------------------
// TribeMembershipRequest
// ---------------------------------------------------------------------------

model TribeMembershipRequest {
  id         Int                      @id @default(autoincrement())
  tribeId    Int                      @map("tribe_id")
  sellerId   String                   @map("seller_id") @db.Uuid
  status     MembershipRequestStatus  @default(PENDING)
  message    String?
  reviewNote String?                  @map("review_note")

  // Líder que revisó la solicitud
  reviewedById String?   @map("reviewed_by_id") @db.Uuid
  reviewedAt   DateTime? @map("reviewed_at") @db.Timestamptz
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz

  // Relations
  tribe      Tribe   @relation(fields: [tribeId], references: [id], onDelete: Cascade)
  seller     Seller  @relation("MembershipRequestedBy", fields: [sellerId], references: [id], onDelete: Cascade)
  reviewedBy Seller? @relation("MembershipReviewedBy", fields: [reviewedById], references: [id])

  @@unique([tribeId, sellerId])
  @@index([tribeId, status])
  @@map("tribe_membership_request")
}

// ---------------------------------------------------------------------------
// ProductCategory
// ---------------------------------------------------------------------------

model ProductCategory {
  id              Int     @id @default(autoincrement())
  categoryName    String  @map("category_name") @db.VarChar(100)
  subcategoryName String? @map("subcategory_name") @db.VarChar(100)

  // Relations
  products Product[]

  @@map("product_category")
}

// ---------------------------------------------------------------------------
// Product
// ---------------------------------------------------------------------------

model Product {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  sellerId       String   @map("seller_id") @db.Uuid
  categoryId     Int      @map("category_id")
  name           String   @db.VarChar(255)
  description    String?
  price          Decimal  @db.Decimal(12, 2)
  stockAvailable Int      @default(0) @map("stock_available")
  imageUrl       String?  @map("image_url")
  averageRating  Decimal? @map("average_rating") @db.Decimal(3, 2)
  totalReviews   Int      @default(0) @map("total_reviews")
  isActive       Boolean  @default(true) @map("is_active")

  // Spatial
  locationCoords           Unsupported("geography(Point, 4326)")? @map("location_coords")
  locationMapboxId         String?                                @map("location_mapbox_id") @db.VarChar(100)
  locationFormattedAddress String?                                @map("location_formatted_address")
  locationCity             String?                                @map("location_city") @db.VarChar(100)
  locationRegion           String?                                @map("location_region") @db.VarChar(100)

  // General elaboration description (if not using step-by-step)
  elaborationText      String?                                @map("elaboration_text") @db.Text
  elaborationMediaUrls String[]                               @map("elaboration_media_urls")

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  // Relations
  seller           Seller                   @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  category         ProductCategory          @relation(fields: [categoryId], references: [id])
  ratings          ProductRating[]
  orders           ProductOrder[]
  comments         ProductComment[]
  elaborationSteps ProductElaborationStep[]

  @@index([sellerId])
  @@index([locationCoords], type: Gist)
  @@index([isActive])
  @@map("product")
}

// ---------------------------------------------------------------------------
// ProductElaborationStep
// ---------------------------------------------------------------------------

model ProductElaborationStep {
  id          Int      @id @default(autoincrement())
  productId   String   @map("product_id") @db.Uuid
  stepNumber  Int      @map("step_number")
  title       String?  @db.VarChar(255)
  description String   @db.Text
  mediaUrls   String[] @map("media_urls")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz

  // Relations
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, stepNumber])
  @@index([productId])
  @@map("product_elaboration_step")
}

// ---------------------------------------------------------------------------
// ProductRating  (composite PK: one rating per user per product)
// ---------------------------------------------------------------------------

model ProductRating {
  productId     String   @map("product_id") @db.Uuid
  userAccountId String   @map("user_account_id") @db.Uuid
  ratingValue   Int      @map("rating_value")
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz

  // Relations
  product Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  user    UserAccount @relation(fields: [userAccountId], references: [id], onDelete: Cascade)

  @@id([productId, userAccountId])
  @@map("product_rating")
}

// ---------------------------------------------------------------------------
// ProductComment (Comentarios e Hilos de Respuesta)
// ---------------------------------------------------------------------------

model ProductComment {
  id              Int       @id @default(autoincrement()) @map("id_comentario")
  productId       String    @map("id_producto") @db.Uuid
  userId          String    @map("id_usuario") @db.Uuid
  content         String    @map("comentario") @db.Text
  parentCommentId Int?      @map("id_respuesta")
  publishedAt     DateTime  @default(now()) @map("fh_publicacion") @db.Timestamptz

  // Relaciones
  product       Product          @relation(fields: [productId], references: [id], onDelete: Cascade)
  user          UserAccount      @relation(fields: [userId], references: [id], onDelete: Cascade)
  parentComment ProductComment?  @relation("CommentReplies", fields: [parentCommentId], references: [id])
  replies       ProductComment[] @relation("CommentReplies")

  @@map("comentarios_productos")
}

// ---------------------------------------------------------------------------
// ShippingCarrier (Catálogo de empresas de paquetería)
// ---------------------------------------------------------------------------

model ShippingCarrier {
  id      Int     @id @default(autoincrement())
  name    String  @unique @db.VarChar(100)
  website String? @db.VarChar(255)

  // Prisma require esta relación inversa para saber que una empresa puede tener muchas órdenes
  orders ProductOrder[]

  @@map("shipping_carrier")
}

// ---------------------------------------------------------------------------
// ProductOrder
// ---------------------------------------------------------------------------

model ProductOrder {
  id                String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  productId         String      @map("product_id") @db.Uuid
  buyerId           String      @map("buyer_id") @db.Uuid
  quantity          Int
  totalAmount       Decimal     @map("total_amount") @db.Decimal(12, 2)
  orderNotes        String?     @map("order_notes")
  trackingNumber    String?     @map("tracking_number") @db.VarChar(100)
  sensorId          String?     @map("sensor_id") @db.VarChar(100)
  carrierId         Int?        @map("carrier_id")
  sellerRatingValue Int?        @map("seller_rating_value")
  buyerRatingValue  Int?        @map("buyer_rating_value")
  transactionHash   String?     @map("transaction_hash") @db.VarChar(255)
  currentStatus     OrderStatus @default(PENDING) @map("current_status")

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  // Relations
  product       Product              @relation(fields: [productId], references: [id])
  buyer         UserAccount          @relation("BuyerOrders", fields: [buyerId], references: [id])
  carrier       ShippingCarrier?     @relation(fields: [carrierId], references: [id])
  statusHistory OrderStatusHistory[]
  chatMessages  OrderChat[]          @relation("OrderChatMessages")
  blockchainRecord  BlockchainRecord?

  @@index([buyerId])
  @@index([currentStatus])
  @@index([sensorId])
  @@map("product_order")
}

// ---------------------------------------------------------------------------
// OrderStatusHistory  (append-only audit log)
// ---------------------------------------------------------------------------

model OrderStatusHistory {
  id              Int          @id @default(autoincrement())
  orderId         String       @map("order_id") @db.Uuid
  changedByUserId String       @map("changed_by_user_id") @db.Uuid
  previousStatus  OrderStatus? @map("previous_status")
  newStatus       OrderStatus  @map("new_status")
  statusNote      String?      @map("status_note")
  createdAt       DateTime     @default(now()) @map("created_at") @db.Timestamptz

  // Relations
  order         ProductOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  changedByUser UserAccount  @relation("ChangedByUser", fields: [changedByUserId], references: [id])

  @@index([orderId, createdAt])
  @@map("order_status_history")
}

// ---------------------------------------------------------------------------
// OrderChat (Mensajería entre vendedor y comprador por pedido)
// ---------------------------------------------------------------------------

model OrderChat {
  id         Int      @id @default(autoincrement()) @map("id_mensaje")
  orderId    String   @map("id_pedido") @db.Uuid
  senderId   String   @map("id_remitente") @db.Uuid
  message    String   @map("mensaje") @db.Text
  sentAt     DateTime @default(now()) @map("fh_envio") @db.Timestamptz

  // Relaciones
  order  ProductOrder @relation("OrderChatMessages", fields: [orderId], references: [id], onDelete: Cascade)
  sender UserAccount  @relation("SentChatMessages", fields: [senderId], references: [id], onDelete: Cascade)

  @@index([orderId, sentAt])
  @@map("chat")
}

// ---------------------------------------------------------------------------
// OutboxEvent  (transactional outbox — reliable Redis Streams publishing)
// ---------------------------------------------------------------------------

model OutboxEvent {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  aggregateType String    @map("aggregate_type") @db.VarChar(100)
  aggregateId   String    @map("aggregate_id") @db.Uuid
  eventType     String    @map("event_type") @db.VarChar(100)
  payload       Json
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz
  publishedAt   DateTime? @map("published_at") @db.Timestamptz

  @@index([publishedAt])
  @@map("outbox_events")
}

// ---------------------------------------------------------------------------
// RefreshToken
// ---------------------------------------------------------------------------

model RefreshToken {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  tokenHash String    @map("token_hash") @db.VarChar(255)
  expiresAt DateTime  @map("expires_at") @db.Timestamptz
  revokedAt DateTime? @map("revoked_at") @db.Timestamptz
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz

  user UserAccount @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tokenHash])
  @@map("refresh_token")
}

// ---------------------------------------------------------------------------
// BlockchainRecord  (1-to-1 extension of ProductOrder)
// ---------------------------------------------------------------------------

model BlockchainRecord {
  id               String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orderId          String           @unique @map("order_id") @db.Uuid
  transactionHash  String?          @map("transaction_hash") @db.VarChar(255)
  blockNumber      Int?             @map("block_number")
  networkName      String           @default("arbitrum") @map("network_name") @db.VarChar(50)
  status           BlockchainStatus @default(PENDING)
  retryCount       Int              @default(0) @map("retry_count")
  errorMessage     String?          @map("error_message")
  gasUsed          String?          @map("gas_used") @db.VarChar(50)
  submittedAt      DateTime?        @map("submitted_at") @db.Timestamptz
  confirmedAt      DateTime?        @map("confirmed_at") @db.Timestamptz
  createdAt        DateTime         @default(now()) @map("created_at") @db.Timestamptz

  // Relations
  order            ProductOrder     @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([transactionHash])
  @@map("blockchain_record")
}
