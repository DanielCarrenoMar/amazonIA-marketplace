# Example environment variables for the backend
# Copy this file to .env and fill with real values (do NOT commit secrets)

# PostgreSQL / Neon connection string
DATABASE_URL=

# JWT secrets used to sign access and refresh tokens
JWT_SECRET=
JWT_REFRESH_SECRET=

# Supabase (storage) configuration
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# Frontend origin allowed for CORS
FRONTEND_URL=

# Server port
PORT=3001

MONGODB_URI=

# NOTE:
# - Keep secrets out of version control. Use a secrets manager in production.
# - The product schema's image_url column is expected to exist in the database.
