# Example environment variables for the backend
# Copy this file to .env and fill with real values (do NOT commit secrets)

# PostgreSQL / Neon connection string
DATABASE_URL=

# JWT secrets used to sign access and refresh tokens
JWT_SECRET=
JWT_REFRESH_SECRET=

# Supabase (storage) configuration
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# Frontend origin allowed for CORS
FRONTEND_URL=

# Server port
PORT=3001

# MongoDB Atlas connection string (telemetry time-series data)
MONGODB_URI=

# Upstash Redis (Streams)
REDIS_URL=
REDIS_TOKEN=

# Circuit Breaker — Resiliencia ante fallos de MongoDB
#
# CB_FAILURE_THRESHOLD: cuántos fallos consecutivos de MongoDB se toleran antes de abrir el circuito
#   y dejar de intentar consultas. Con 3, al tercer fallo seguido el sistema se rinde temporalmente.
#   Valor bajo (1-2) = muy sensible, abre rápido. Valor alto (5-10) = tolera más fallos esporádicos.
CB_FAILURE_THRESHOLD=3
#
# CB_COOLDOWN_MS: milisegundos que el circuito permanece ABIERTO antes de intentar de nuevo.
#   Durante este tiempo todas las consultas a MongoDB se saltan directamente (respuesta inmediata).
#   Al cumplirse, deja pasar UNA petición de prueba: si funciona el circuito se cierra,
#   si falla vuelve a esperar este mismo tiempo. 30000 = 30 segundos.
CB_COOLDOWN_MS=30000
#
# MONGODB_TIMEOUT_MS: tiempo máximo en milisegundos que se espera la respuesta de una query
#   antes de considerarla fallida y contarla como fallo para el circuit breaker.
#   Evita que una query lenta bloquee el servidor indefinidamente. 5000 = 5 segundos.
MONGODB_TIMEOUT_MS=5000

# --- Blockchain Notary Integration ---
# Comunicación Interna (API Key compartida con blockchain-notary)
NOTARY_API_KEY=

# URL del microservicio notario (blockchain-notary)
NOTARY_SERVICE_URL=http://localhost:3004/api/v1

# URL base del backend para webhooks (el notario llamará aquí)
WEBHOOK_BASE_URL=http://localhost:3000/api

# Dev-only: key for role promotion endpoint
DEV_ROLE_KEY=

# NOTE:
# - Keep secrets out of version control. Use a secrets manager in production.
# - The product schema's image_url column is expected to exist in the database.
