{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": "..",
  "testEnvironment": "node",
  "testMatch": ["<rootDir>/test/e2e/**/*.e2e-spec.ts"],
  "moduleNameMapper": {
    "^event-types$": "<rootDir>/../../packages/event-types/src/index.ts"
  },
  "transform": {
    "^.+\\.(t|j)s$": "ts-jest"
  }
}
